# API基础配置
API_BASE_URL=http://localhost:8080

# 管理端 Token (用于 /api/v1/admin/* 接口)
# 从管理端登录接口获取，或从浏览器开发者工具中获取
ADMIN_TOKEN=your_admin_token_here

# 用户端 Token (用于 /api/v1/wth/* 等用户端接口)
# 从用户端登录接口获取，或从浏览器开发者工具中获取
USER_TOKEN=your_user_token_here

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=my_stonks

# 测试配置
TEST_TIMEOUT=30

# 注意：
# 1. 运行测试前，请将此文件复制为 .env
# 2. 填写真实的 ADMIN_TOKEN 和 USER_TOKEN
# 3. Token 可以从登录接口返回的 data.token 中获取
